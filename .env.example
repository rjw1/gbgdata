# Database Configuration
DB_USER=user
DB_PASSWORD=password
DB_NAME=gbgdata
DATABASE_URL=postgres://user:password@localhost:5432/gbgdata

# Geocoding Configuration (Optional)
# Leave NOMINATIM_URL empty to disable geocoding features
# For local docker-compose usage: http://nominatim:8080/search
NOMINATIM_URL=

# Leptos configuration
LEPTOS_SITE_ADDR=127.0.0.1:3000
LEPTOS_SITE_ROOT=site
